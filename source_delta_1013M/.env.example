# Xiaobei local provider configuration example.
# Do not commit real tokens.

XIAOBEI_AI_PROVIDER_DEFAULT=openai_compatible
XIAOBEI_AI_MODEL_DEFAULT=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MINIMAX_API_KEY=
MINIAMX_API_KEY=
MINIMAX_MODEL=MiniMax-M3

# 067B default: never read OPENCLAW auth profiles unless explicitly enabled for local development.
XIAOBEI_ALLOW_OPENCLAW_AUTH_PROFILE=0
XIAOBEI_OPENCLAW_AUTH_PROFILE_PATH=
XIAOBEI_OPENCLAW_AUTH_PROFILE_ALLOWLIST_ROOT=
